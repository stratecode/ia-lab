# ─── Host & System ───────────────────────────────────────────────────────────
ANSIBLE_VAULT_PASSWORD_FILE=~/.config/ia-lab/ansible-vault-pass
LAB_HOSTNAME=myhost.local
LAB_STATIC_IP=192.168.1.100
LAB_USER=myuser
LAB_TIMEZONE=Europe/Madrid
LAB_LAN_CIDR=192.168.1.0/24
LAB_GPU_TYPE=amd

# ─── Domains ────────────────────────────────────────────────────────────────
LAB_DOMAIN=myhost.local
LAB_CODEX_GATEWAY_DOMAIN=codex.example.com
LAB_COCKPIT_DOMAIN=lab.example.com
LAB_OBSERVABILITY_DOMAIN=monitor.example.com
LAB_CHAT_DOMAIN=chat.example.com

# ─── DNS (Route53 DDNS) ─────────────────────────────────────────────────────
LAB_DNS_ZONE_NAME=example.com
LAB_DNS_HOSTED_ZONE_ID=Z0123456789ABCDEF
LAB_DNS_RECORD_NAME=vpn.example.com
LAB_DNS_AWS_PROFILE=route53-dns

# ─── TLS / Let's Encrypt ────────────────────────────────────────────────────
LAB_TLS_MODE=letsencrypt
LAB_LETSENCRYPT_EMAIL=admin@example.com
LAB_LETSENCRYPT_CHALLENGE=dns-route53
LAB_LETSENCRYPT_AWS_PROFILE=route53-dns
LAB_OPEN_WEBUI_SECRET_KEY=replace-with-random-hex
LAB_OPEN_WEBUI_VERSION=v0.9.5
LAB_OPEN_WEBUI_ENABLE_SIGNUP=true
LAB_ORCHESTRATOR_PROXY_PATH=/orchestrator/

# ─── AI Models (llama.cpp) ──────────────────────────────────────────────────
# Variable pattern: LAB_LLAMA_<ROLE>_<PARAM>
# Roles: CODE, PLANNER, UTILITY, EMBEDDINGS
# Params: MODEL, PORT, CTX_SIZE, THREADS, PARALLEL, GPU_LAYERS, API_KEY

# Code instance (priority 1 — always-on)
# Primary coding assistant. Highest resource allocation and GPU offload.
LAB_LLAMA_CODE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_CODE_PORT=8080
LAB_LLAMA_CODE_CTX_SIZE=16384
LAB_LLAMA_CODE_THREADS=6
LAB_LLAMA_CODE_PARALLEL=1
LAB_LLAMA_CODE_GPU_LAYERS=33
LAB_LLAMA_CODE_API_KEY=your-code-api-key-here

# Codex local gateway effective context guardrails.
# Keep llama.cpp at 16k for throughput, but advertise/guard a smaller window
# to avoid unstable very-large prompts on small integrated GPUs.
LAB_CODEX_GATEWAY_CONTEXT_WINDOW=12000
LAB_CODEX_GATEWAY_AUTO_COMPACT_TOKEN_LIMIT=8000
LAB_CODEX_GATEWAY_MAX_PROMPT_CHARS=30000
LAB_CODEX_GATEWAY_DEFAULT_MAX_OUTPUT_TOKENS=4096
LAB_CODEX_GATEWAY_RESPONSE_STORE_TTL_MINUTES=30
LAB_CODEX_GATEWAY_RESPONSE_STORE_MAX_ENTRIES=256

# Planner instance (priority 2 — warm)
# Task decomposition and planning. Loaded on boot, suspendable under pressure.
LAB_LLAMA_PLANNER_MODEL=Qwen/Qwen2.5-3B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_PLANNER_PORT=8082
LAB_LLAMA_PLANNER_CTX_SIZE=16384
LAB_LLAMA_PLANNER_THREADS=4
LAB_LLAMA_PLANNER_PARALLEL=2
LAB_LLAMA_PLANNER_GPU_LAYERS=20
LAB_LLAMA_PLANNER_API_KEY=your-planner-api-key-here

# Utility instance (priority 3 — lazy)
# Lightweight tasks (summarization, classification). Loaded on first request.
LAB_LLAMA_UTILITY_MODEL=Qwen/Qwen2.5-1.5B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_UTILITY_PORT=8083
LAB_LLAMA_UTILITY_CTX_SIZE=8192
LAB_LLAMA_UTILITY_THREADS=4
LAB_LLAMA_UTILITY_PARALLEL=1
LAB_LLAMA_UTILITY_GPU_LAYERS=16
LAB_LLAMA_UTILITY_API_KEY=your-utility-api-key-here

# Embeddings instance (priority 4 — warm)
# Vector embeddings for RAG pipelines. CPU-only, loaded on boot.
LAB_LLAMA_EMBEDDINGS_MODEL=nomic-ai/nomic-embed-text-v1.5-GGUF:Q8_0
LAB_LLAMA_EMBEDDINGS_PORT=8084
LAB_LLAMA_EMBEDDINGS_CTX_SIZE=8192
LAB_LLAMA_EMBEDDINGS_THREADS=2
LAB_LLAMA_EMBEDDINGS_PARALLEL=2
LAB_LLAMA_EMBEDDINGS_GPU_LAYERS=99
LAB_LLAMA_EMBEDDINGS_API_KEY=your-embeddings-api-key-here

# ─── WireGuard ──────────────────────────────────────────────────────────────
LAB_WG_SUBNET=10.66.66.0/24
LAB_WG_SERVER_ADDRESS=10.66.66.1/24
LAB_WG_SERVER_IP=10.66.66.1
LAB_WG_PORT=51820
LAB_WG_CLIENT_ADDRESS=10.66.66.2/32

# ─── Aider Agent Runtime ────────────────────────────────────────────────────
# Timeouts and concurrency
LAB_AIDER_TASK_TIMEOUT=600
LAB_AIDER_TEST_TIMEOUT=300
LAB_AIDER_MAX_CONCURRENT=2
LAB_AIDER_QUEUE_TIMEOUT=300

# Workspace limits (bytes)
LAB_AIDER_MAX_WORKSPACE_DISK=10737418240
LAB_AIDER_MAX_WORKSPACE_SIZE=1073741824

# Aider model and execution settings
LAB_AIDER_EDIT_FORMAT=whole
LAB_AIDER_MAP_TOKENS=1024
LAB_AIDER_MAX_CHAT_HISTORY_TOKENS=2048
LAB_AIDER_MODEL_NAME=coder
LAB_AIDER_DEFAULT_MODE=autonomous
LAB_AIDER_API_BASE=http://127.0.0.1:8080/v1

# ─── Orchestrator Platform (Phase 4) ───────────────────────────────────────
LAB_ORCHESTRATOR_ENABLED=true
LAB_ORCHESTRATOR_MODE=all
LAB_ORCHESTRATOR_HOST=127.0.0.1
LAB_ORCHESTRATOR_PORT=8100
LAB_ORCHESTRATOR_SAFE_MODE=true
LAB_ORCHESTRATOR_LOG_LEVEL=INFO
LAB_ORCHESTRATOR_CLEANUP_KEY_NAME=workspace-cleanup-timer
LAB_ORCHESTRATOR_CLEANUP_API_KEY=replace-with-random-hex
LAB_ORCHESTRATOR_OPEN_WEBUI_KEY_NAME=open-webui-orchestrator-tools
LAB_ORCHESTRATOR_OPEN_WEBUI_API_KEY=replace-with-random-hex
LAB_ORCHESTRATOR_BACKUP_RETAIN_COUNT=7
LAB_ORCHESTRATOR_GO_BINARY_PATH=/absolute/path/to/dist/orchestrator-go-linux-amd64
LAB_ORCHESTRATOR_GO_HOST=127.0.0.1
LAB_ORCHESTRATOR_GO_PORT=8100
LAB_AGENT_BASE_URL=http://127.0.0.1:8100
LAB_AGENT_API_KEY=
LAB_AGENT_WORKSPACE_ROOT=/abs/path/to/current/workspace
LAB_AGENT_BRIDGE_ID=
LAB_AGENT_NAME=lab-agentd
LAB_AGENT_POLL_INTERVAL=2s
LAB_AGENT_HEARTBEAT_INTERVAL=15s
LAB_CAPABILITIES_DOCS_SIDECAR_URL=http://127.0.0.1:8221
LAB_CAPABILITIES_IMAGES_SIDECAR_URL=http://127.0.0.1:8222

LAB_POSTGRES_DB=orchestrator
LAB_POSTGRES_USER=orchestrator
LAB_POSTGRES_PASSWORD=replace-with-strong-password

LAB_REDIS_URL=redis://127.0.0.1:6379/0

LAB_WORKER_HEARTBEAT_INTERVAL=30
LAB_SCHEDULER_MAX_CONCURRENT_TASKS=3
LAB_QUEUE_MAX_GLOBAL=200
LAB_QUEUE_MAX_PER_AGENT=50
LAB_RATE_LIMIT_PER_KEY=20
LAB_WORKSPACE_RETENTION_HOURS=24
LAB_CAPABILITIES_ALLOWED_LOCAL_ROOTS=/srv/ai-lab,/tmp
LAB_CAPABILITIES_ALLOWED_URL_SCHEMES=http,https,file
LAB_CAPABILITIES_MAX_HTML_BYTES=1500000
LAB_CAPABILITIES_MAX_DOCUMENT_BYTES=20000000
LAB_CAPABILITIES_MAX_IMAGE_BYTES=10000000
LAB_CAPABILITIES_MAX_ARTIFACT_TEXT_CHARS=16000
LAB_CAPABILITIES_PLANNER_ALLOWED=web.search,web.fetch,document.read
LAB_CAPABILITIES_CODER_ALLOWED=
LAB_OPENAI_BASE_URL=https://api.openai.com/v1
LAB_OPENAI_REFERENCE_API_KEY=
LAB_OPENAI_REFERENCE_MODEL=gpt-4o-mini
LAB_OPENAI_JUDGE_MODEL=gpt-4o-mini
LAB_OPENAI_TIMEOUT_SECONDS=45
LAB_LLAMA_PLANNER_BASE_URL=http://127.0.0.1:8082/v1
LAB_LLAMA_PLANNER_API_KEY=local-planner
LAB_LLAMA_UTILITY_BASE_URL=http://127.0.0.1:8083/v1
LAB_LLAMA_UTILITY_API_KEY=local-utility
LAB_AIDER_TASK_PATH=/usr/local/bin/aider-task
LAB_AIDER_TIMEOUT_SECONDS=1800
LAB_AIDER_DEFAULT_BRANCH=main

LAB_TELEGRAM_BOT_TOKEN=replace-with-telegram-token
LAB_TELEGRAM_ALLOWED_USERS=123456789
LAB_LLAMA_THREAD_BUDGET=16
