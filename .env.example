# ─── Host & System ───────────────────────────────────────────────────────────
LAB_HOSTNAME=myhost.local
LAB_STATIC_IP=192.168.1.100
LAB_USER=myuser
LAB_TIMEZONE=Europe/Madrid
LAB_LAN_CIDR=192.168.1.0/24
LAB_GPU_TYPE=amd

# ─── Domains ────────────────────────────────────────────────────────────────
LAB_DOMAIN=myhost.local
LAB_COCKPIT_DOMAIN=lab.example.com
LAB_OBSERVABILITY_DOMAIN=monitor.example.com

# ─── DNS (Route53 DDNS) ─────────────────────────────────────────────────────
LAB_DNS_ZONE_NAME=example.com
LAB_DNS_HOSTED_ZONE_ID=Z0123456789ABCDEF
LAB_DNS_RECORD_NAME=vpn.example.com
LAB_DNS_AWS_PROFILE=route53-dns

# ─── TLS / Let's Encrypt ────────────────────────────────────────────────────
LAB_TLS_MODE=letsencrypt
LAB_LETSENCRYPT_EMAIL=admin@example.com
LAB_LETSENCRYPT_CHALLENGE=dns-route53
LAB_LETSENCRYPT_AWS_PROFILE=route53-dns

# ─── AI Models (llama.cpp) ──────────────────────────────────────────────────
# Code instance
LAB_LLAMA_CODE_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_CODE_PORT=8080
LAB_LLAMA_CODE_CTX_SIZE=32000
LAB_LLAMA_CODE_THREADS=6
LAB_LLAMA_CODE_PARALLEL=2
LAB_LLAMA_CODE_GPU_LAYERS=99
LAB_LLAMA_CODE_API_KEY=change-me

# Chat instance
LAB_LLAMA_CHAT_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_CHAT_PORT=8081
LAB_LLAMA_CHAT_CTX_SIZE=32000
LAB_LLAMA_CHAT_THREADS=6
LAB_LLAMA_CHAT_PARALLEL=2
LAB_LLAMA_CHAT_GPU_LAYERS=99
LAB_LLAMA_CHAT_API_KEY=change-me

# ─── WireGuard ──────────────────────────────────────────────────────────────
LAB_WG_SUBNET=10.66.66.0/24
LAB_WG_SERVER_ADDRESS=10.66.66.1/24
LAB_WG_SERVER_IP=10.66.66.1
LAB_WG_PORT=51820
LAB_WG_CLIENT_ADDRESS=10.66.66.2/32
