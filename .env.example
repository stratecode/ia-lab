# ─── Host & System ───────────────────────────────────────────────────────────
ANSIBLE_VAULT_PASSWORD_FILE=~/.config/ia-lab/ansible-vault-pass
LAB_HOSTNAME=myhost.local
LAB_STATIC_IP=192.168.1.100
LAB_USER=myuser
LAB_TIMEZONE=Europe/Madrid
LAB_LAN_CIDR=192.168.1.0/24
LAB_GPU_TYPE=amd

# ─── Domains ────────────────────────────────────────────────────────────────
LAB_DOMAIN=myhost.local
LAB_COCKPIT_DOMAIN=lab.example.com
LAB_OBSERVABILITY_DOMAIN=monitor.example.com

# ─── DNS (Route53 DDNS) ─────────────────────────────────────────────────────
LAB_DNS_ZONE_NAME=example.com
LAB_DNS_HOSTED_ZONE_ID=Z0123456789ABCDEF
LAB_DNS_RECORD_NAME=vpn.example.com
LAB_DNS_AWS_PROFILE=route53-dns

# ─── TLS / Let's Encrypt ────────────────────────────────────────────────────
LAB_TLS_MODE=letsencrypt
LAB_LETSENCRYPT_EMAIL=admin@example.com
LAB_LETSENCRYPT_CHALLENGE=dns-route53
LAB_LETSENCRYPT_AWS_PROFILE=route53-dns

# ─── AI Models (llama.cpp) ──────────────────────────────────────────────────
# Variable pattern: LAB_LLAMA_<ROLE>_<PARAM>
# Roles: CODE, PLANNER, UTILITY, EMBEDDINGS
# Params: MODEL, PORT, CTX_SIZE, THREADS, PARALLEL, GPU_LAYERS, API_KEY

# Code instance (priority 1 — always-on)
# Primary coding assistant. Highest resource allocation and GPU offload.
LAB_LLAMA_CODE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_CODE_PORT=8080
LAB_LLAMA_CODE_CTX_SIZE=32000
LAB_LLAMA_CODE_THREADS=6
LAB_LLAMA_CODE_PARALLEL=2
LAB_LLAMA_CODE_GPU_LAYERS=33
LAB_LLAMA_CODE_API_KEY=your-code-api-key-here

# Planner instance (priority 2 — warm)
# Task decomposition and planning. Loaded on boot, suspendable under pressure.
LAB_LLAMA_PLANNER_MODEL=Qwen/Qwen2.5-3B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_PLANNER_PORT=8082
LAB_LLAMA_PLANNER_CTX_SIZE=16384
LAB_LLAMA_PLANNER_THREADS=4
LAB_LLAMA_PLANNER_PARALLEL=2
LAB_LLAMA_PLANNER_GPU_LAYERS=20
LAB_LLAMA_PLANNER_API_KEY=your-planner-api-key-here

# Utility instance (priority 3 — lazy)
# Lightweight tasks (summarization, classification). Loaded on first request.
LAB_LLAMA_UTILITY_MODEL=Qwen/Qwen2.5-1.5B-Instruct-GGUF:Q4_K_M
LAB_LLAMA_UTILITY_PORT=8083
LAB_LLAMA_UTILITY_CTX_SIZE=8192
LAB_LLAMA_UTILITY_THREADS=2
LAB_LLAMA_UTILITY_PARALLEL=1
LAB_LLAMA_UTILITY_GPU_LAYERS=0
LAB_LLAMA_UTILITY_API_KEY=your-utility-api-key-here

# Embeddings instance (priority 4 — warm)
# Vector embeddings for RAG pipelines. CPU-only, loaded on boot.
LAB_LLAMA_EMBEDDINGS_MODEL=nomic-ai/nomic-embed-text-v1.5-GGUF:Q8_0
LAB_LLAMA_EMBEDDINGS_PORT=8084
LAB_LLAMA_EMBEDDINGS_CTX_SIZE=8192
LAB_LLAMA_EMBEDDINGS_THREADS=2
LAB_LLAMA_EMBEDDINGS_PARALLEL=4
LAB_LLAMA_EMBEDDINGS_GPU_LAYERS=0
LAB_LLAMA_EMBEDDINGS_API_KEY=your-embeddings-api-key-here

# ─── WireGuard ──────────────────────────────────────────────────────────────
LAB_WG_SUBNET=10.66.66.0/24
LAB_WG_SERVER_ADDRESS=10.66.66.1/24
LAB_WG_SERVER_IP=10.66.66.1
LAB_WG_PORT=51820
LAB_WG_CLIENT_ADDRESS=10.66.66.2/32
