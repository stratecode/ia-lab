{
  "id": "httpie-cli-negative-review",
  "repo_id": "httpie-cli",
  "case_type": "negative_case",
  "goal": "Run a deterministic benchmark workflow for HTTPie CLI and validate a narrow local test without borrowing unrelated CLI memory.",
  "repo_profile": "python_cli_application",
  "project_type": "existing_repo",
  "runtime_or_stack": "python",
  "project_root": ".",
  "test_focus": "local CLI utility review",
