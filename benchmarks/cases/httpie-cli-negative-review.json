    "/bin/bash",
    "-lc",
    "python -m pip install -q -e .[test] pytest && pytest -q tests/test_cli_utils.py"
  ],
  "expected_files": [
    "httpie/cli/utils.py",
    "tests/test_cli_utils.py"
  ],
  "coder_tool": "write_file",
  "patch_target": ".lab/repo-workflow-marker.txt",
  "write_content": "httpie benchmark marker\n",
  "coder_summary": "Write a deterministic benchmark marker file before repository review.",
  "benchmark_memory_strategy": "semantic_only",
  "benchmark_league": "negative_transfer",
  "sequence_id": "negative_transfer_httpie",
