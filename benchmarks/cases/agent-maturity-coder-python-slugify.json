{
  "id": "agent-maturity-coder-python-slugify",
  "repo_id": "typer",
  "case_type": "review_only",
  "goal": "Apply a deterministic Typer marker patch and validate coder execution quality on a repo that already has a stable smoke command.",
  "repo_profile": "python_cli_framework",
