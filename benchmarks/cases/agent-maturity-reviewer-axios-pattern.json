{
  "id": "agent-maturity-reviewer-axios-pattern",
  "repo_id": "axios",
  "case_type": "review_only",
  "goal": "Review a deterministic Axios repository change and preserve evidence that will later transfer to another HTTP client without relying on repo-specific memory.",
  "repo_profile": "javascript_http_client_library",
  "project_type": "existing_repo",
  "runtime_or_stack": "javascript",
  "language": "javascript",
  "problem_domain": "http_client",
  "validation_pattern": "manifest_integrity",
  "project_root": ".",
  "test_focus": "reviewer validation quality for HTTP client repositories",
  "test_command": [
    "docker",
    "run",
    "--rm",
    "-v",
    "{{ project_root_abs }}:/src",
    "-w",
    "/src",
    "node:22",
    "/bin/bash",
    "-lc",
    "node -e \"const fs=require('fs'); const pkg=JSON.parse(fs.readFileSync('package.json','utf8')); if(!pkg.name){process.exit(1)} console.log(pkg.name)\""
  ],
  "expected_files": ["package.json"],
  "coder_tool": "write_file",
  "patch_target": ".lab/reviewer-pattern-marker.txt",
  "write_content": "reviewer pattern marker\n",
  "coder_summary": "Write a deterministic reviewer pattern marker file before repository review.",
  "benchmark_memory_strategy": "pattern_first",
  "benchmark_league": "pattern_transfer",
  "sequence_id": "agent_maturity_reviewer_http_clients",
  "sequence_position": 1,
  "maturity_block": "execution_maturity",
  "primary_agent": "reviewer",
  "expected_handoffs": [
    "coder->reviewer"
  ],
  "success_contract": {
    "required_agents": ["researcher", "coder", "reviewer"],
    "expected_launch_order": ["researcher", "coder", "reviewer"],
    "requires_coder_approval": true,
    "expected_coder_tool": "write_file",
    "initiative_must_complete": true,
    "review_must_pass": true,
    "reject_toolchain_confusion": true
  },
  "reference_eval_mode": "review_quality"
}
