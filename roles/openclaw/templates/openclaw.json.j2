{
  "gateway": {
    "mode": "local",
    "auth": {
    "mode": "token",
      "token": {{ openclaw_effective_gateway_token | tojson }}
    },
    "controlUi": {
      "allowedOrigins": {{ openclaw_control_ui_allowed_origins | tojson }}
    },
    "trustedProxies": {{ openclaw_trusted_proxies | tojson }}
  },
  "models": {
    "providers": {
      "{{ openclaw_model_provider_key }}": {
        "baseUrl": {{ openclaw_model_base_url | tojson }},
        "apiKey": {{ openclaw_model_api_key | tojson }},
        "api": {{ openclaw_model_provider_api | tojson }},
        "timeoutSeconds": {{ openclaw_llama_timeout_seconds }},
        "models": [
          {
            "id": {{ openclaw_model_id | tojson }},
            "name": {{ openclaw_model_name | tojson }},
            "reasoning": false,
            "input": ["text"],
            "contextWindow": {{ openclaw_model_context_window }},
            "maxTokens": {{ openclaw_llama_max_tokens }},
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "models": {
        "{{ openclaw_model_provider_key }}/{{ openclaw_model_id }}": {
{% if openclaw_model_force_tool_choice %}
          "params": {
            "tool_choice": "required",
            "parallel_tool_calls": {{ openclaw_model_parallel_tool_calls | tojson }}
          }
{% endif %}
        }
      },
      "model": {
        "primary": "{{ openclaw_model_provider_key }}/{{ openclaw_model_id }}"
      },
      "contextTokens": {{ openclaw_model_context_window }},
      "compaction": {
        "reserveTokens": 4096,
        "reserveTokensFloor": 2048
      },
      "skills": [],
      "experimental": {
        "localModelLean": true
      },
      "bootstrapMaxChars": 50000,
      "bootstrapTotalMaxChars": 300000,
      "contextInjection": "always"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": {{ openclaw_telegram_enabled | tojson }}
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": {{ openclaw_telegram_enabled | tojson }},
      "name": {{ openclaw_telegram_channel_name | tojson }},
      "botToken": {{ openclaw_telegram_bot_token | tojson }}
    }
  },
  "commands": {
    "ownerAllowFrom": {{ openclaw_owner_allow_from | tojson }}
  },
  "update": {
    "auto": {
      "enabled": {{ openclaw_update_auto_enabled | tojson }}
    },
    "checkOnStart": {{ openclaw_update_check_on_start | tojson }}
  },
  "diagnostics": {
    "cacheTrace": {
      "enabled": true,
      "includeSystem": true
    }
  },
  "tui": {
    "footer": {
      "showRemoteHost": true
    }
  },
  "web": {
    "enabled": {{ openclaw_web_enabled | tojson }}
  },
  "nodeHost": {
    "browserProxy": {
      "allowProfiles": []
    }
  },
  "media": {
    "preserveFilenames": true
  },
  "acp": {
    "allowedAgents": [],
    "enabled": true
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    }
  },
  "memory": {
    "citations": "auto",
    "backend": "builtin"
  }
}
